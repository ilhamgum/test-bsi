{
    "semi": false,
    "singleQuote": false,
    "tabWidth": 4,
    "printWidth": 120,
    "bracketSpacing": true,
    "trailingComma": "es5",
    "plugins": ["@trivago/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
    "importOrder": [
        "^react$",
        "^next/",
        "<THIRD_PARTY_MODULES>",
        "^@/components/",
        "^@/common/",
        "^@/features/",
        "^@/mocks/",
        "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
}
